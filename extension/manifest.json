{
  "manifest_version": 3,
  "name": "OpenWebAI SSE Interceptor",
  "version": "1.0.1",
  "description": "Intercepts DeepSeek SSE/fetch streams and forwards to local relay server",
  "permissions": ["storage", "tabs", "alarms", "scripting"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://www.deepseek.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*"
      ]
    }
  ]
}
